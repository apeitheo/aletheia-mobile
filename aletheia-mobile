ALETHEIA="$HOME/.aletheia-mobile/"
LANGUAGE="English"
ALETHEIA_DATA_DIR="$(dirname "$0")"
ALETHEIA_PID="$$"
CONFIG_FILE="$ALETHEIA/config"
MAX_VOLUME="100"
LOOP_MODE=false
FADE_VOLUME=false
loop_sub=0.05000
_title=
