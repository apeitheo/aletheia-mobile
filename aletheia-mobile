else
	flags="--pulse-buffer=1500"
fi
mpv --title=ALETHEIA_MOBILE_INTERNAL_SERVER --gapless-audio=yes "$flags" --hr-seek=yes --input-terminal=yes --cache-pause-initial=yes --video=no --idle --volume=$MAX_VOLUME --input-ipc-server="$MPV_PIPE" --af=equalizer=f=32:g=${_BASS},equalizer=f=64:g=${_BASS},equalizer=f=125:g=${_BASS},equalizer=f=250:g=${_MID},equalizer=f=500:g=${_MID},equalizer=f=1000:g=${_MID},equalizer=f=2000:g=${_MID},equalizer=f=4000:g=${_TREB},equalizer=f=8000:g=${_TREB},equalizer=f=16000:g=${_TREB} </dev/null 2>/dev/null &
MPV_PID="$!"

touch -m "$ALETHEIA/start$$"

_save_setting() {
    local CLEAN_CONFIG
    CLEAN_CONFIG=$(echo -e "$CONFIG" | grep -v "^$1[[:space:]]*=")

    if [ -z "$CLEAN_CONFIG" ]; then
        CONFIG="$1=$2"
    else
        CONFIG="$CLEAN_CONFIG\n$1=$2"
    fi

    echo -e "$CONFIG" > "$CONFIG_FILE"
}

WORDS=
for i in "$ALETHEIA_DATA_DIR"/language.*; do
	WORDS+="$(<"$i")"
	WORDS+=$'\n'
	WORDS+=$'\n'
done

word_lookup() {
	local reply=
	if [ "$LANGUAGE" != "English" ]; then
		reply="$(grep "$LANGUAGE:$1:" <<<"$WORDS" | cut -d':' -f3-)"
		if [ -z "$reply" ]; then
			echo -ne "$1"
		else
			echo -ne "$reply"
		fi
	else
		echo -ne "$1"
	fi
}

is_num() {
	if [[ "$1" =~ ^-?[0-9]+(\.[0-9]*)?$ ]]; then
		if [[ "$1" == *"."* ]]; then
			echo -n "2"
		else
			echo -n "1"
		fi
	else
		echo -n "0"
	fi
}

speak() {
	if [ "$VOICE_ENABLED" == true ] || [ "$2" == true ]; then
		if [ "$SPEECH_ENGINE" == "gtts" ] || [ "$SPEECH_ENGINE" == "gtts-cli" ]; then
			pkill -f "^mpv --title=ALETHEIA_MOBILE_INTERNAL -$"
			if [ "$LANGUAGE" == "German" ];then
				gtts-cli -l de "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Spanish" ]; then
				gtts-cli -l es "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Hindi" ]; then
				gtts-cli -l hi "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Chinese" ]; then
				gtts-cli -l zh "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Japanese" ]; then
				gtts-cli -l ja "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			else
				gtts-cli "${1//-/,}," | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			fi
		#elif [ "$SPEECH_ENGINE" == "piper" ]; then
		#	pkill piper
		#	piper -m "en_US"*onnx "${1//-/,}" &
		else
			pkill -f "^mpv --title=ALETHEIA_MOBILE_INTERNAL -$"
			if [ "$LANGUAGE" == "German" ];then
				espeak-ng --stdout -v de+m1 "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Spanish" ]; then
				espeak-ng --stdout -v es+m1 "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Hindi" ]; then
				espeak-ng --stdout -v hi+m1 "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Chinese" ]; then
				espeak-ng --stdout -v yue+m1 "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			elif [ "$LANGUAGE" == "Japanese" ]; then
				espeak-ng --stdout -v ja+m1 "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			else
				espeak-ng --stdout "${1//-/,}" | mpv --title=ALETHEIA_MOBILE_INTERNAL - &
			fi
		fi
	fi
}

add_downloaded() {
	sort -o "$ALETHEIA/incoming" "$ALETHEIA/incoming"
	comm -23 "$ALETHEIA/incoming" "$ALETHEIA/renamed" >"$ALETHEIA/incoming.new"
	mv "$ALETHEIA/incoming.new" "$ALETHEIA/incoming"
	list="$(grep -E "\.(${AUDIO_FORMATS//,/|})$" "$ALETHEIA/incoming" )"
	echo -n "" >"$ALETHEIA/incoming"
	echo -n "" >"$ALETHEIA/renamed"
	unset DOWNLOAD_POSITION
	if [ "${list:0:1}" != "" ]; then
		mapfile -O "$TOTAL_QUEUE" -t QUEUE <<<"$list"
		TOTAL_QUEUE=${#QUEUE[@]}
		DOWNLOAD_POSITION=$((TOTAL_QUEUE-1))
	else
		echo -e "$(word_lookup "NO DOWNLOADS")" > "$INT_PIPE"
	fi
	touch -m "$ALETHEIA/start$$"
	DISPLAY_OPTIONS=false
}

if [ ! -e "$ALETHEIA/archived/" ]; then
	if ! mkdir "$ALETHEIA/archived/"; then
		exit 1
	fi
fi

if [ ! -e "$MUSIC_DIR" ]; then
	echo "$MUSIC_DIR: No such directory"
	exit 1
fi

if ! mkfifo "$MPV_PIPE"; then
	exit 1
fi

rm -f "$ALETHEIA/web_client_pipe"* >/dev/null 2>&1

if ! mkfifo "$WEB_PIPE"; then
	exit 1
fi

exec 3<> "$MPV_PIPE"
exec 4<> "$WEB_PIPE"

mapfile -t QUEUE < <(find "$MUSIC_DIR" -type f -iregex "$regex" -and -not -name ".*" -not -path "*${SOUND_DIR%/}*" | shuf)
TOTAL_QUEUE="${#QUEUE[@]}"

echo -n "" > "$ALETHEIA/incoming"
echo -n "" > "$ALETHEIA/renamed"
(inotifywait -m -e create -e moved_to --format '%w%f' "$MUSIC_DIR" | while read -r new_file
do
	basename="$(basename "$new_file")"
	if [ "${basename:0:1}" != "." ]; then
		echo "$new_file" >>"$ALETHEIA/incoming"
	fi
done) &
INOTIFY_PID="$!"

if [ "$TOTAL_QUEUE" == "0" ]; then
	echo "Nothing found in $MUSIC_DIR"
	exit 1
fi
fade_volume() {
	if [ "$FADE_VOLUME" == true ]; then
		get_system_volume
		local VOLUME="${SYSTEM_VOLUME_LEFT//%/}"
		REVERT_TO="${SYSTEM_VOLUME_LEFT//%/}"
		VOLUME="${VOLUME%%.*}"
		up=false
		down=true
		PAUSE_IND=1
		echo "1/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
		while [ "$VOLUME" -ge "0" ] && [ "$VOLUME" -le "100" ]; do
			if [ "$up" == true ]; then
				if [ "$VOLUME" == "100" ]; then
					return
				fi

				if [ "$VOLUME" -lt "30" ]; then
					VOLUME="$(calc -pd "$VOLUME+10")"
				else
					VOLUME="$(calc -pd "$VOLUME+2")"
				fi

				if [ "$VOLUME" -gt "100" ]; then
					VOLUME=100
				elif [ "$VOLUME" -lt "0" ]; then
					VOLUME=0
				fi

				echo -e "set volume $VOLUME" | socat - "$MPV_PIPE" >/dev/null

				echo "$VOLUME" > "$INT_PIPE"
			elif [ "$down" == true ]; then
				if [ "$VOLUME" == "0" ]; then
					if [ "$PAUSE" == true ]; then
						break
					fi
					return
				fi
				VOLUME="$(calc -pd "$VOLUME-2")"
			fi
			if [ "$VOLUME" -gt "100" ]; then
				VOLUME=100
			elif [ "$VOLUME" -lt "0" ]; then
				VOLUME=0
			fi
			echo -e "set volume $VOLUME" | socat - "$MPV_PIPE" >/dev/null

			echo "$VOLUME" > "$INT_PIPE"
			if [ "$up" == true ]; then
				read -rsn1 -t 0.075 c < "$WEB_PIPE"
				if [ "$VOLUME" == "100" ]; then
					break
				fi
			elif [ "$down" == true ]; then
				read -rsn1 -t 0.090 c < "$WEB_PIPE"
				if [ "$VOLUME" == "0" ]; then
					break
				fi
			fi
			ps -p "$MPV_PID" >/dev/null 2>/dev/null
			if [ "$c" == "F" ]; then
				STOP=true
				STAY_STOPPED=true
				UNHOOK=false
				PAUSE=true
				_title=
				PAUSE_IND=1
				echo "1/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
				echo -e "$((POSITION+1)) / $TOTAL_QUEUE" > "$INT_PIPE"
				echo stop | socat - "$MPV_PIPE" >/dev/null
				return
			elif [ "$c" == "p" ] && [ "$up" == false ]; then
				echo -e "set volume 0" | socat - "$MPV_PIPE" >/dev/null
				return
			fi
			x=$((x+1))
		done
	fi
}

update_limits() {
	INTERVAL_LOWER_LIMIT=$(bc <<<"$EDO*2.6")
	INTERVAL_UPPER_LIMIT=$(bc <<<"$EDO*2.1")
	INTERVAL_LOWER_LIMIT="${INTERVAL_LOWER_LIMIT%.*}"
	INTERVAL_UPPER_LIMIT="${INTERVAL_LOWER_LIMIT%.*}"
}

INTERVAL=0
EDO=60
EDO_LIMIT="1000000"
FFMPEG_PID=

if [ -e "${QUEUE[0]}.locked" ]; then
	IFS='/' read -r INTERVAL EDO _ < "${QUEUE[0]}.locked"
fi
if [ "$STAY_STOPPED" == false ]; then
	echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
else
	echo -e "1 / $TOTAL_QUEUE" > "$INT_PIPE"
fi
update_limits

POSITION=0

PAUSE_IND=1
echo "1/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &

update_cover_art() {
		fp="${QUEUE[$1]##*/}"
		{
			if [ ! -e "${QUEUE[$1]}.art" ]; then
				if ffmpeg -i "${QUEUE[$1]}" -an -vcodec copy "$ALETHEIA/$fp.jpg" >/dev/null 2>&1; then
					mv "$ALETHEIA/$fp.jpg" "${QUEUE[$1]}.art" 2>/dev/null
				fi
				echo "1/$POS/${QUEUE[$1]}" > "$PAUSE_PIPE" &
			else
				echo "1/$POS/${QUEUE[$1]}" > "$PAUSE_PIPE" &
			fi
		} &
		FFMPEG_PID="$!"
}

update_cover_art "0"

launch_mpv() {
	loop_sub=0.05000
	LOOP_MODE=false
	start=
	get_system_volume
	if [ "$FADE_VOLUME" == true ]; then
		VOL="$REVERT_TO"
	else
		VOL="${SYSTEM_VOLUME_LEFT//%/}"
	fi
	__BASS="$_BASS:$_BASS:$_BASS"
	__MID="$_MID:$_MID:$_MID:$_MID"
	__TREB="$_TREB:$_TREB:$_TREB"
	_title="${QUEUE[$1]}"
	_title="${_title##*/}"
	_title="${_title%.*}"
	i=25
	if ! ps -p "$MPV_PID" >/dev/null; then
		exit 1
	else
		spd=$(calc -pd "2^($INTERVAL/$EDO)")
		echo -e "loadfile \"${QUEUE[$1]}\" replace -1 pause=no,pitch=$spd,speed=$spd,volume=$VOL,ab-loop-a=0,ab-loop-b=0,loop-file=0\nset af \"equalizer=f=32:g=${_BASS},equalizer=f=64:g=${_BASS},equalizer=f=125:g=${_BASS},equalizer=f=250:g=${_MID},equalizer=f=500:g=${_MID},equalizer=f=1000:g=${_MID},equalizer=f=2000:g=${_MID},equalizer=f=4000:g=${_TREB},equalizer=f=8000:g=${_TREB},equalizer=f=16000:g=${_TREB}\"" | socat - "$MPV_PIPE" >/dev/null
		LOOP=false
	fi
}

node "$ALETHEIA_DATA_DIR/aletheia-webserver.js" &
NODE_PID="$!"

echo

title="${QUEUE[0]##*/}"
printf "%s\n" "${QUEUE[@]}" | sed -n "$((first+1)),$((last+1))p" | rev | cut -d'.' -f2- | cut -d'/' -f1 | rev | sed -e "s/\n/<br\/>/g" >"$ALETHEIA/current_queue.new"

mv "$ALETHEIA/current_queue.new" "$ALETHEIA/current_queue"

update_limits

cleanup_sigint() {
	kill "$NODE_PID" 2>/dev/null
	kill "$MPV_PID" 2>/dev/null
	kill "$INOTIFY_PID" 2>/dev/null
	reset
	exit 1
}

trap cleanup_sigint SIGINT

write_current_queue() {
	if [ "$POSITION" -lt "3" ] || [ "$TOTAL_QUEUE" -le "5" ]; then
		first=0
		pos="$POSITION"
	elif [ "$POSITION" -gt "$((TOTAL_QUEUE-3))" ]; then
		first="$((TOTAL_QUEUE-5))"
		if [ "$((TOTAL_QUEUE-POSITION))" == "1" ]; then
			pos=4
		else
			pos=3
		fi
	else
		first="$((POSITION-2))"
		pos="2"
	fi
	last="$((first+4))"
	if [ "$last" -ge "$TOTAL_QUEUE" ]; then
		last="$((TOTAL_QUEUE-1))"
	fi
	title="${QUEUE[POSITION]##*/}"
	if [ "$UNHOOK" == true ]; then
		_unhook=1
	else
		_unhook=0
	fi

	printf "%s\n" "${QUEUE[@]##*/}" | sed -n "$((first+1)),$((last+1))p" | rev | cut -d'.' -f2- | rev | awk -v pos="$pos" -v title="$_title" -v unhook="$_unhook" '
{
	line = $0
	if ((NR-1) == pos) {
		if (unhook == 1) {
			printf "<div class=\"interval_highlight\">%s</div><br/>\\n", $0;
		} else {
			printf "<div class=\"interval_current\">%s</div><br/>\\n", $0;
		}
	} else if (line == title) {
		printf "<div class=\"interval_hook\">%s</div><br/>\\n", $0;
	} else {
		printf "<div class=\"interval_other\">%s</div><br/>\\n", $0;
	}	
}' > "$QUEUE_PIPE"

	echo > "$QUEUE_PIPE"

	title="${QUEUE[POSITION]##*/}"
	echo "${title%.*}" > "$TITLE_PIPE"
}

speak_title() {
	if [ "$VOICE_ENABLED" == true ] || [ "$TITLE_ONLY" == true ]; then
		title="${QUEUE[POSITION]##*/}"
		speak " ${title%.*}" true &
	fi
}

write_current_queue
speak_title

get_system_volume() {
	reply="$(echo '{ "command": ["get_property", "volume"] }' | socat - "$MPV_PIPE")"
	SYSTEM_VOLUME_LEFT="${reply#*\"data\":}"
	SYSTEM_VOLUME_LEFT="${SYSTEM_VOLUME_LEFT%%,*}"
	SYSTEM_VOLUME_LEFT="${SYSTEM_VOLUME_LEFT//[[:space:]]/}"
	SYSTEM_VOLUME_LEFT="${SYSTEM_VOLUME_LEFT%%.*}"
	SYSTEM_VOLUME_LEFT="$SYSTEM_VOLUME_LEFT%"
	SYSTEM_VOLUME_RIGHT="$SYSTEM_VOLUME_LEFT"
}

while [ "$POSITION" -lt "$TOTAL_QUEUE" ]; do
	IFS= read -rsn1 -t 1.5 key < "$WEB_PIPE"
	if [ -z "$key" ]; then
		if [ "$LOOP_MODE" == true ]; then
			echo -e "$start / $end" > "$INT_PIPE"
		else
			if [ "$DISPLAY_OPTIONS" == false ]; then
				if [ "$DISPLAY_EQ" == true ]; then
					echo "$_BASS : $_MID : $_TREB" > "$INT_PIPE"
				else
					if [ "$STAY_STOPPED" == false ]; then
						echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
					else
						echo -e "$((POSITION+1)) / $TOTAL_QUEUE" > "$INT_PIPE"
					fi
				fi
			fi
		fi
	fi
	reply="$(echo '{ "command": ["get_property", "percent-pos"] }' | socat - "$MPV_PIPE")"

	#POS="${reply#*\"data\":}"
	#POS="${POS%%,*}"
	#POS="${POS//[[:space:]]/}"
	POS=$(echo '{ "command": ["get_property", "percent-pos"] }' | socat - "$MPV_PIPE" | jq -r '.data')
	echo "$PAUSE_IND/$POS/${QUEUE[POSITION]}" >"$PAUSE_PIPE"

	tmp9="$(echo '{ "command": ["get_property", "idle-active"] }' | socat - "$MPV_PIPE")"
	tmp9="${tmp9#*\"data\":}"
	tmp9="${tmp9%%,*}"
	tmp9="${tmp9//[[:space:]]/}"
	if [ $STAY_STOPPED == false ] && [ "$tmp9" == true ]; then
		if [ "$UNHOOK" == false ]; then
			((POSITION++))
			if [ "$POSITION" == "$TOTAL_QUEUE" ]; then
				POSITION=0
			fi
			_title="${QUEUE[POSITION]}"
			_title="${_title##*/}"
			_title="${_title%.*}"
			write_current_queue
			speak_title
			INTERVAL=0
			EDO=60
			if [ -e "${QUEUE[POSITION]}.locked" ]; then
