GREEN="\033[1;32m"
NOCOLOR="\033[0m"
RED="\033[1;31m"
YELLOW="\033[1;33m"

QUIT=false
check_dep() {
	local dependency_name="$1"
	local only_warn="$2"

	echo -ne "${NOCOLOR}Checking for $dependency_name... "

	if [ ! -x "$(command -v "$dependency_name")" ]; then
		if [ "$only_warn" != true ]; then
			echo -e "${RED}no${NOCOLOR}"
			QUIT=true
		else
			echo -e "${YELLOW}no${NOCOLOR}"
		fi
	else
		echo -e "${GREEN}yes${NOCOLOR}"
	fi
}

check_dep bash
check_dep bc
check_dep calc
check_dep espeak-ng
check_dep exiftool
check_dep ffmpeg
check_dep mpv
check_dep node
check_dep inotifywait
check_dep socat
check_dep jq
check_dep gtts-cli true

echo

if [ "$QUIT" == true ]; then
	echo -e "${RED}Error: Missing dependencies.${NOCOLOR}"
	exit 1
fi

PIPER_AVAILABLE=false
if command -v piper >/dev/null; then
	PIPER_AVAILABLE=true
fi
PIPER_AVAILABLE=false

GTTS_AVAILABLE=false
if command -v gtts-cli >/dev/null; then
	GTTS_AVAILABLE=true
fi

if command -v termux-wake-lock >/dev/null; then
	termux-wake-lock
fi

list="$(pgrep -f "aletheia-mobile" | grep -v "^$$$")"
for i in $list; do
	kill "$i" 2>/dev/null
done
pkill -f "^inotifywait -m -e create -e moved_to --format %w%f $MUSIC_DIR" 2>/dev/null
pkill -f "^node .*aletheia-webserver.js" 2>/dev/null
pkill -f "^mpv --title=ALETHEIA_MOBILE_INTERNAL_SERVER" 2>/dev/null

value="$HOME/Music"
sounds_value="$HOME/Sounds"
if [ -e "$CONFIG_FILE" ]; then
	value1="$(grep -i "^MUSIC_DIR[[:space:]]*=" < "$CONFIG_FILE")"
	value1="${value1#*=}"
	value1="$(sed "s/^[[:space:]]*//g;s/\"//g;s/'//g" <<< "$value1")"

	value2="$(grep -i "^SOUND_DIR[[:space:]]*=" < "$CONFIG_FILE")"
	value2="${value2#*=}"
	value2="$(sed "s/^[[:space:]]*//g;s/\"//g;s/'//g" <<< "$value2")"

	value3="$(grep -i "^SPEECH_ENGINE[[:space:]]*=" < "$CONFIG_FILE")"
	value3="${value3#*=}"
	value3="$(sed "s/^[[:space:]]*//g;s/\"//g;s/'//g" <<< "$value3")"

	if [ -n "$value1" ]; then
		value="$value1"
	fi
	if [ -n "$value2" ]; then
		sounds_value="$value2"
	fi
	if [ -n "$value3" ]; then
		SPEECH_ENGINE="$value3"
		case "$SPEECH_ENGINE" in
			"gtts"|"gtts-cli"|"espeak-ng"|"espeak")
				;;
			*)
				SPEECH_ENGINE="espeak-ng"
				;;
		esac
	fi
fi

MUSIC_DIR="$(realpath "$value")"
MUSIC_DIR="$(printf '%s/' "$MUSIC_DIR")"

SOUND_DIR="$(realpath "$sounds_value")"
SOUND_DIR="$(printf '%s/' "$SOUND_DIR")"

CONFIG=
if [ -e "$CONFIG_FILE" ]; then
	value="$(grep -i "^LANGUAGE[[:space:]]*=" < "$CONFIG_FILE")"
	value="${value#*=}"
	value="$(sed "s/^[[:space:]]*//g;s/\"//g;s/'//g" <<< "$value")"
	if [ -n "$value" ]; then
		LANGUAGE="$value"
	fi
	CONFIG="$(<"$CONFIG_FILE")"
fi

