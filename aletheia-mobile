		;;
	'#')
		echo -e "$start/$end" >"${QUEUE[POSITION]}.loops"
		echo -e "$(word_lookup "SAVED")" > "$INT_PIPE"
		;;
	'?')
		if [ -e "${QUEUE[POSITION]}.loops" ]; then
			full="$(cat "${QUEUE[POSITION]}.loops")"
			start="${full%/*}"
			end="${full#*/}"
			echo -e "set ab-loop-a $start\nset ab-loop-b $end\nseek $start absolute" | socat - "$MPV_PIPE" >/dev/null
			LOOP_MODE=true
		fi
		echo -e "$(word_lookup "LOADED")" > "$INT_PIPE"
		;;
	'!')
		if [ "$LOOP_MODE" == true ]; then
			LOOP_MODE=false
			echo -e "$(word_lookup "LOOP OFF")" > "$INT_PIPE"
			echo -e "set ab-loop-a no\nset ab-loop-b no" | socat - "$MPV_PIPE" >/dev/null
			start=
			end=
		else
			if [ "$STAY_STOPPED" == false ]; then
				LOOP_MODE=true
				if [ "${start:0:1}" == "" ]; then
					start=0.00000
					end=1.50000
				fi
				echo -e "$(word_lookup "LOOP ON")" > "$INT_PIPE"
				echo -e "set ab-loop-a $start\nset ab-loop-b $end" | socat - "$MPV_PIPE" >/dev/null
				echo -e "seek $start absolute" | socat - "$MPV_PIPE" >/dev/null
			fi
		fi
		;;
	'v')
		if [ "$(bc <<<"$loop_sub >= 0.0125")" == "1" ]; then
			loop_sub="$(bc <<<"scale=5; $loop_sub / 2")"
			loop_sub="${loop_sub//^./0.}"
		fi
		echo -e "$loop_sub" > "$INT_PIPE"
		;;
	'V')
		loop_sub="$(bc <<<"scale=5; $loop_sub * 2")"
		loop_sub="${loop_sub//^./0.}"
		echo -e "$loop_sub" > "$INT_PIPE"
		;;
	'1')
		if [ "$LOOP_MODE" == true ]; then
			start=$(bc <<<"$start+$loop_sub")
			tmpu="$(bc <<<"$start >= $end")"
			if [ "$tmpu" == "1" ]; then
				start=$(bc <<<"$start-$loop_sub")
			fi
			start="${start//^./0.}"
			if [ "${start:0:1}" == "." ]; then
				start="${start//./0.}"
			fi
			echo -e "set ab-loop-a $start" | socat - "$MPV_PIPE" >/dev/null
			echo -e "$start / $end" > "$INT_PIPE"
		fi
		;;
	'2')
		if [ "$LOOP_MODE" == true ]; then
			if [ "$(bc <<<"($start-$loop_sub)>=0")" == "1" ]; then
				start=$(bc <<<"$start-$loop_sub")
				start="${start//^./0.}"
				if [ "${start:0:1}" == "." ]; then
					start="${start//./0.}"
				fi
				echo -e "set ab-loop-a $start" | socat - "$MPV_PIPE" >/dev/null
			fi
			echo -e "$start / $end" > "$INT_PIPE"
		fi
		;;
	'3')
		if [ "$LOOP_MODE" == true ]; then
			end=$(bc <<<"$end+$loop_sub")
			if [ "${end:0:1}" == "." ]; then
				end="${end//./0.}"
			fi
			seek=$(bc <<<"$end-1.5")
			echo -e "set ab-loop-b $end" | socat - "$MPV_PIPE" >/dev/null
			echo -e "$start / $end" > "$INT_PIPE"
		fi
		;;
	'6')
		if [ "$LOOP_MODE" == true ]; then
			end=$(bc <<<"$end-$loop_sub")
			tmpu="$(bc <<<"$start >= $end")"
			if [ "$tmpu" == "1" ]; then
				end=$(bc <<<"$end+$loop_sub")
			fi

			if [ "${end:0:1}" == "." ]; then
				end="${end//./0.}"
			fi
			echo -e "set ab-loop-b $end" | socat - "$MPV_PIPE" >/dev/null
			echo -e "$start / $end" > "$INT_PIPE"
		fi
		;;
	'O')
		seek=$(bc <<<"$end-2")
		echo -e "seek $seek absolute" | socat - "$MPV_PIPE" >/dev/null
		;;
	'i')
		if [ "$POSITION" -lt "$((TOTAL_QUEUE-1))" ]; then
			tmp1="${QUEUE[POSITION]}"
			QUEUE[POSITION]="${QUEUE[POSITION+1]}"
			if [ "$UNHOOK" == true ]; then
				if [ "$POSITION" == "$((OLD_POS-1))" ]; then
					((UNHOOK_OFFSET--))
				fi
			fi
			((POSITION++))
			QUEUE[POSITION]="$tmp1"
			write_current_queue
		else
			tmp1="${QUEUE[POSITION]}"
			QUEUE[POSITION]="${QUEUE[0]}"
			if [ "$UNHOOK" == true ]; then
				UNHOOK_OFFSET=$((TOTAL_QUEUE-UNHOOK_OFFSET))
			fi
			POSITION=0
			QUEUE[POSITION]="$tmp1"
			write_current_queue
		fi
		;;
	'I')
		if [ "$POSITION" -gt "0" ]; then
			tmp1="${QUEUE[POSITION]}"
			QUEUE[POSITION]="${QUEUE[POSITION-1]}"
			if [ "$UNHOOK" == true ]; then
				UNHOOK_OFFSET=$((TOTAL_QUEUE-1))
			fi
			((POSITION--))
			QUEUE[POSITION]="$tmp1"
			write_current_queue
		else
			tmp1="${QUEUE[POSITION]}"
			QUEUE[POSITION]="${QUEUE[TOTAL_QUEUE-1]}"
			if [ "$UNHOOK" == true ]; then
				if [ "$POSITION" == "$((OLD_POS+UNHOOK_OFFSET+1))" ]; then
					((UNHOOK_OFFSET++))
				fi
			fi
			POSITION=$((TOTAL_QUEUE-1))
			QUEUE[POSITION]="$tmp1"
			write_current_queue
		fi
		;;
	'R')
		current_file="${QUEUE[POSITION]##*/}"
		full="${QUEUE[POSITION]}"
		mapfile -t QUEUE -O 1 < <(printf "%s\n" "${QUEUE[@]}" | grep -v "$current_file" | shuf)
		QUEUE[0]="$full"
		TOTAL_QUEUE="${#QUEUE[@]}"
		POSITION=0
		write_current_queue
		if [ "$VOICE_ENABLED" == true ]; then
			speak "$(word_lookup "shuffled")"
		fi
		;;
	'A')
		current_file="${QUEUE[POSITION]}"
		IFS=$'\n'
		mapfile -t QUEUE < <(printf "%s\n" "${QUEUE[@]}" | awk -F '/' '{printf "%s", $NF; print $0}' | sort | cut -d'' -f2)
		unset IFS
		POSITION=$(printf '%s\n' "${QUEUE[@]}" | grep --text -n "$current_file" | cut -d':' -f1 | head -1)
		((POSITION--))
		write_current_queue
		speak "$(word_lookup "sorted")"
		;;
	's')
		read -r line < "$WEB_PIPE"
		echo -e "$line"
		ln="$(printf "%s\n" "${QUEUE[@]}" | grep -n "" | sed -n "/${line//+/.*}/Ip")"
		ln="${ln%%:*}"
		if [ -n "$ln" ]; then
			((ln--))
			POSITION="$ln"
			speak_title
			INTERVAL=0
			EDO=60
			if [ -e "${QUEUE[POSITION]}.locked" ]; then
				IFS='/' read -r INTERVAL EDO _ < "${QUEUE[POSITION]}.locked"
			fi
			update_limits
			update_cover_art "$POSITION"
			if [ "$STAY_STOPPED" == false ]; then
				fade_volume
				launch_mpv "$POSITION"
				echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
				PAUSE=false
				PAUSE_IND=0
				echo "0/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
			else
				echo -e "$((POSITION+1)) / $TOTAL_QUEUE" > "$INT_PIPE"
			fi
		else
			speak "$(word_lookup "nothing found")" &
		fi
		write_current_queue
		;;
	'U')
		speak "$(word_lookup "archive canceled")" &
		;;
	'u')
		speak "$(word_lookup "click to archive file")" &
		;;
	'r')
		artist="$(exiftool -Artist "${QUEUE[POSITION]}" | head -1 | cut -d':' -f2-)"
		title="$(exiftool -Title "${QUEUE[POSITION]}" | head -1 | cut -d':' -f2-)"
		artist="${artist//\//-}"
		title="${title//\//-}"
		cp "${QUEUE[POSITION]}" "${QUEUE[POSITION]}.bkp"
		ext="${QUEUE[POSITION]##*.}"
		mv "${QUEUE[POSITION]}" "$MUSIC_DIR/${artist# } - ${title# }.$ext"
		if [ -e "${QUEUE[POSITION]}.art" ]; then
			mv "${QUEUE[POSITION]}.art" "$MUSIC_DIR/${artist# } - ${title# }.$ext.art"
		fi
		if [ -e "${QUEUE[POSITION]}.locked" ]; then
			mv "${QUEUE[POSITION]}.locked" "$MUSIC_DIR/${artist# } - ${title# }.$ext.locked"
		fi
		echo -n "$MUSIC_DIR/${artist# } - ${title# }.$ext" >>"$ALETHEIA/renamed"
		sort -o "$ALETHEIA/renamed" "$ALETHEIA/renamed"
		QUEUE[POSITION]="$MUSIC_DIR/${artist# } - ${title# }.$ext"
		write_current_queue
		;;
	'M')
		if [ "$MUTE" == true ]; then
			MUTE=false
			echo cycle mute | socat - "$MPV_PIPE" >/dev/null
			speak "$(word_lookup "unmuted")" &
		else
			MUTE=true
			speak "$(word_lookup "muted")"
			echo cycle mute | socat - "$MPV_PIPE" >/dev/null
		fi
		;;
	'D')
		speak "$(word_lookup "archived file")" &	
		mv "${QUEUE[POSITION]}" "$ALETHEIA/archived/"
		if [ "$POSITION" == "$((TOTAL_QUEUE-1))" ]; then
			POSITION=0
		else
			((POSITION++))
		fi
		_title=
		write_current_queue
		speak_title
			
		INTERVAL=0
		EDO=60
		if [ -e "${QUEUE[POSITION]}.locked" ]; then
			IFS='/' read -r INTERVAL EDO _ < "${QUEUE[POSITION]}.locked"
		fi
		update_limits
		update_cover_art "$POSITION"
		echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
		launch_mpv "$POSITION"
		PAUSE=false
		PAUSE_IND=0
		echo "0/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
		;;
	"\\")
		if [ "$STAY_STOPPED" == false ]; then
			if [ "$PAUSE" == true ]; then
				echo -e "seek 0 absolute\nset pause no" | socat - "$MPV_PIPE" >/dev/null
			else
				echo -e "seek 0 absolute" | socat - "$MPV_PIPE" >/dev/null
			fi
			PAUSE=false
			speak "$(word_lookup "restarted")" &
			PAUSE_IND=0
			echo "0/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
		fi
		;;
	'<')
		speak "$(word_lookup "menu")" &
		DISPLAY_EQ=false
		DISPLAY_OPTIONS=false
		;;
	'>')
		speak "$(word_lookup "options")" &
		DISPLAY_EQ=false
		DISPLAY_OPTIONS=false
		;;
	'Q')
		speak "$(word_lookup "loop")" &
		DISPLAY_EQ=false
		DISPLAY_OPTIONS=false
		;;
	'_')
		if [ "$FADE_VOLUME" == false ] && [ "$PAUSE" == false ]; then
			FADE_VOLUME=true
			speak "$(word_lookup "fade on")" &
			echo -e "$(word_lookup "FADE ON")" > "$INT_PIPE"
		else
			FADE_VOLUME=false
			if [ "$STAY_STOPPED" == false ]; then
				speak "$(word_lookup "fade off")" &
				echo -e "$(word_lookup "FADE OFF")" > "$INT_PIPE"
			else
				echo -e "$(word_lookup "NOTHING PLAYING")" > "$INT_PIPE"
			fi
		fi
		;;
	'&')
		if [ "$STAY_STOPPED" == false ]; then
			if [ "$UNHOOK" == true ]; then
				UNHOOK=false
				if [ "$PAUSE" == false ]; then
					PAUSE_IND=0
					echo "0/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
				fi
				POSITION=0

				for i in "${!QUEUE[@]}"; do
					if [[ "${QUEUE[$i]}" == "$CURRENT_SONG" ]]; then
						POSITION=$i
						break
					fi
				done
				speak "$(word_lookup "hooked")" &
				#if [ "$TITLE_ONLY" == true ]; then
				#	kill_speak
				#	play -n synth 0.1 sine 200 &
				#fi
				_title=
				update_cover_art "$POSITION"
				write_current_queue
			else
				CURRENT_SONG="${QUEUE[POSITION]}"
				OLD_POS="$POSITION"
				UNHOOK_OFFSET=0
				UNHOOK=true
				speak "$(word_lookup "unhooked")" &
				#if [ "$TITLE_ONLY" == true ]; then
				#	kill_speak
				#	play -n synth 0.1 sine 150 &
				#fi
				if [ "$PAUSE" == false ]; then
					PAUSE_IND=1
					echo "1/$POS/${QUEUE[POSITION]}" > "$PAUSE_PIPE" &
				fi
				_title="${QUEUE[POSITION]}"
				_title="${_title##*/}"
				_title="${_title%.*}"
				write_current_queue
			fi
		else
			echo -e "$(word_lookup "NOTHING PLAYING")" > "$INT_PIPE"
			DISPLAY_OPTIONS=false
		fi
		;;
	'0')
		if [ "$ONLY_STOPPED" == false ]; then
			echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
		fi
		speak "$(word_lookup "music")" &
		DISPLAY_EQ=false
		DISPLAY_OPTIONS=false
		;;
	'C')
		speak "$(word_lookup "album art toggled")" &
		;;
	'z')
		if [ "$STOP" == true ]; then
			STOP=false
			speak "$(word_lookup "playback resumed")" &
			echo -e "$(word_lookup "RESUMED")" > "$INT_PIPE"
		else
			STOP=true
			speak "$(word_lookup "playback stopped")" &
			echo -e "$(word_lookup "HELD")" > "$INT_PIPE"
		fi
		;;
	'y')
		new_edo="60"
		speak "$new_edo" &
		if [ "$new_edo" -gt "$EDO" ]; then
			temp="$(calc -pd "$new_edo/$EDO")"
			INTERVAL="$(calc -pd " $INTERVAL*$temp")"
			INTERVAL="${INTERVAL%%.*}"
		elif [ "$new_edo" -lt "$EDO" ]; then
			temp="$(calc -pd "$EDO/$new_edo")"
			INTERVAL="$(calc -pd " $INTERVAL/$temp")"
			INTERVAL="${INTERVAL%%.*}"
		fi
		EDO="$new_edo"
		echo -e "$INTERVAL / $EDO" > "$INT_PIPE"
		INTERVAL_LOWER_LIMIT=$(bc <<<"$EDO*2.6")
		INTERVAL_UPPER_LIMIT=$(bc <<<"$EDO*2.1")
		INTERVAL_LOWER_LIMIT="${INTERVAL_LOWER_LIMIT%.*}"
		INTERVAL_UPPER_LIMIT="${INTERVAL_LOWER_LIMIT%.*}"
		spd=$(calc -pd "2^($INTERVAL/$EDO)")
		echo -e "set pitch $spd\nset speed $spd" | socat - "$MPV_PIPE" >/dev/null
		;;
	'q')
		echo "quit 0" > "$MPV_PIPE"
		exit 0
		;;
	esac
done
